# .env.example — Khedma AI
# ─────────────────────────────────────────────────────
# Copy this file to .env (never commit .env itself)
# Fill each value before running the application.
# ─────────────────────────────────────────────────────

# ─── BACKEND ──────────────────────────────────────────
NODE_ENV=development
PORT=5000

# Supabase Postgres — use the session pooler URL for migrations,
# the transaction pooler URL for runtime query load.
DATABASE_URL=postgresql://user:password@host:5432/postgres

# Allowed frontend origin for CORS
frontend_URL=http://localhost:5173

# ─── AI Provider Keys (add only the ones you use) ────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_AI_API_KEY=AIza...
GROQ_API_KEY=gsk_...
MISTRAL_API_KEY=...

# ─── FRONTEND (prefix with VITE_ to expose to browser) ──
VITE_API_BASE_URL=http://localhost:5000/api/v1
